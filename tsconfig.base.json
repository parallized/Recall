{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": [
      "bun-types"
    ],
    "baseUrl": ".",
    "paths": {
      "@recall/api": [
        "./apps/api/src/index.ts"
      ],
      "@recall/domain": [
        "./packages/domain/src/index.ts"
      ]
    }
  }
}
